# =============================================================================
# AccountSafe - Oracle Cloud Production Environment
# =============================================================================
# Copy this file to `.env` on the Oracle VM and fill every required value.
#   cp .env.oracle.example .env
#   nano .env
#
# NEVER commit the real .env. It is in .gitignore for this reason.
# =============================================================================

# -----------------------------------------------------------------------------
# Public hostname for the API. Pick ONE of these patterns:
#   1. DuckDNS (recommended): e.g. accountsafe.duckdns.org
#      -> register at https://www.duckdns.org and point it to your VM IP
#   2. sslip.io (zero signup): e.g. 140-245-20-107.sslip.io
#      -> use only if DuckDNS is unavailable; rate limits on Let's Encrypt
#         are shared across sslip.io so prefer DuckDNS for production
#   3. Your own custom domain
# -----------------------------------------------------------------------------
DOMAIN=your-subdomain.duckdns.org
PUBLIC_IP=YOUR.VM.PUBLIC.IP
LETSENCRYPT_EMAIL=you@example.com

# -----------------------------------------------------------------------------
# Frontend origin (Vercel). Used for CORS + CSRF allow-lists.
# Preview deploys (*.vercel.app) are handled by a regex in settings.py.
# -----------------------------------------------------------------------------
FRONTEND_ORIGIN=https://your-app.vercel.app

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGE-ME-TO-A-50-CHAR-RANDOM-STRING

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE-ME-TO-A-FERNET-KEY

APP_VERSION=1.0.0
GUNICORN_WORKERS=3

# -----------------------------------------------------------------------------
# Database (Postgres container on same VM)
# -----------------------------------------------------------------------------
DB_NAME=accountsafe
DB_USER=accountsafe
# Generate with: openssl rand -base64 32
DB_PASSWORD=CHANGE-ME-TO-A-STRONG-PASSWORD

# -----------------------------------------------------------------------------
# Email (Gmail SMTP)
#   App password: https://myaccount.google.com/apppasswords
# -----------------------------------------------------------------------------
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=AccountSafe <your-gmail@gmail.com>

# -----------------------------------------------------------------------------
# Cloudflare Turnstile (bot protection)
#   https://dash.cloudflare.com -> Turnstile
# -----------------------------------------------------------------------------
TURNSTILE_SECRET_KEY=

# -----------------------------------------------------------------------------
# Sentry error tracking (optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
